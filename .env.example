# =============================================================================
# LuckBot 环境变量示例
# =============================================================================

# -----------------------------------------------------------------------------
# 对话 LLM（agent/llm/client.py → build_llm）
# -----------------------------------------------------------------------------
# 以下三项须全部非空，源码不设默认值；未配置时 build_llm() 会 ValueError。
LUCKBOT_MODEL_BASE_URL=https://api.openai.com/v1
# 作用：OpenAI 兼容 API 的 base URL（聊天、压缩、归档等共用）。
# 必须指向 API 根路径，而不是服务站点首页；常见形式是 .../v1。
LUCKBOT_MODEL_API_KEY=your-api-key
# 作用：上述 API 的密钥。
LUCKBOT_MODEL_NAME=gpt-4o-mini
# 作用：聊天模型名。

# -----------------------------------------------------------------------------
# 运行与日志（app/cli.py、agent/built_in）
# -----------------------------------------------------------------------------
LUCKBOT_RECURSION_LIMIT=25
# 作用：单轮对话内 ReAct 最大步数（LLM 与工具循环上限）。
# 默认：25。空或非法整数回退 25；合法整数与 1 取 max（≤0 视为 1）。
LUCKBOT_LOG_LEVEL=WARNING
# 作用：logging 级别名（如 DEBUG、INFO、WARNING），转大写后交给 logging。
# 默认：WARNING。非法级别名回退为 WARNING。

# -----------------------------------------------------------------------------
# 统一观测（agent/observability、gateway/app.py、agent/runtime/core.py）
# -----------------------------------------------------------------------------
LUCKBOT_OBSERVABILITY_ENABLED=0
# 作用：是否启用 OpenTelemetry 导出。默认：关闭；若显式配置 OTLP endpoint 也可自动启用。
LUCKBOT_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# 作用：OTLP HTTP 导出根地址；通常指向 otel-collector 的 `:4318`。
LUCKBOT_OTEL_EXPORTER_OTLP_HEADERS=
# 作用：OTLP 导出附加 headers，格式示例：`Authorization=Bearer xxx,foo=bar`。
LUCKBOT_OTEL_AUTO_INSTRUMENT_FASTAPI=1
# 作用：是否给 gateway FastAPI 自动加 OTel HTTP 仪表。
LUCKBOT_SERVICE_NAME=luckbot
# 作用：service.name；Grafana / Tempo / Prometheus 中的统一服务标识。
LUCKBOT_SERVICE_VERSION=0.1.0
# 作用：service.version。
LUCKBOT_ENV=dev
# 作用：deployment.environment，如 dev / staging / prod。
LUCKBOT_LANGSMITH_ENABLED=0
# 作用：LuckBot 自己的 LangSmith 开关；当前直写 create_run/update_run，建议与 `LANGSMITH_API_KEY` 配套。
LUCKBOT_LANGSMITH_PROJECT=luckbot
# 作用：LangSmith project 名称。
LANGSMITH_API_KEY=
# 作用：LangSmith 云端 API Key。

# -----------------------------------------------------------------------------
# 会话与持久化（agent/built_in/session_plugin、agent/session/state.py）
# -----------------------------------------------------------------------------
LUCKBOT_SESSION=default
# 作用：逻辑会话键 session_key，映射到“当前活动”的 session_id 与 *.jsonl。
# /new 会为同一 session_key 轮转出新的 session_id，旧 jsonl 会保留为动态记忆来源。
# 默认：空或未设置时为 default。
# LUCKBOT_STATE_DIR=
# 作用：持久化根目录；其下含 sessions/、memory/ 等。
# 默认：未设置或空时为 <project>/.luckbot/state。
LUCKBOT_SESSION_PERSIST=1
# 作用：是否将动态会话日志读写到 sessions/<session_id>.jsonl。
# 默认：开启。关闭：0 / false / no / off（大小写不敏感）；关闭后跨进程不恢复历史、不落盘，/new 仅重置内存会话。

# -----------------------------------------------------------------------------
# 上下文压缩（agent/memory/compaction.py，MemoryPlugin before_llm_call）
# -----------------------------------------------------------------------------
LUCKBOT_CONTEXT_TOKEN_BUDGET=
# 作用：粗略估算的 token 预算；超过才触发压缩。
# 默认：未设置、空串、非整数、≤0 均不启用压缩整段逻辑。
LUCKBOT_CONTEXT_KEEP_RECENT=10
# 作用：压缩后保留消息列表尾部 K 条。
# 默认：10。空或非法整数回退 10。
LUCKBOT_MEMORY_FLUSH=1
# 作用：压缩流程中是否先执行 Memory Flush（仅 agent：带 memory_* 工具的短 ReAct 子循环）。
# 默认：开启。关闭：0 / false / no / off（大小写不敏感）。
# 若 MemoryIndex/嵌入未就绪则跳过 flush 并打日志，无其它回退写盘。
# flush agent 提示词要求：优先写入 memory/YYYY-MM-DD.md（UTC 当日，与触发压缩时的 day 一致）；必要时才改 MEMORY.md 等。
LUCKBOT_MEMORY_FLUSH_MAX_STEPS=12
# 作用：单次压缩前 flush agent 的 ReAct 最大工具轮数。
# LUCKBOT_MEMORY_FLUSH_MAX_WRITE_CHARS=524288
# 作用：memory_write 单请求内容长度上限（字符）。

# -----------------------------------------------------------------------------
# 记忆总开关与路径（agent/memory/paths.py、MemoryPlugin）
# -----------------------------------------------------------------------------
LUCKBOT_MEMORY_ENABLED=1
# 作用：是否加载记忆插件（memory_search / memory_get、索引等）。
# 默认：开启。关闭：0 / false / no / off。
LUCKBOT_OWNER_ID=local
# 作用：多用户隔离子目录：{STATE_DIR}/memory/{OWNER_ID}/。
# 默认：未设置或空为 local。
LUCKBOT_MEMORY_EXTRA_PATHS=
# 作用：把「不在 memory树里」的单个 .md 文件挂进静态记忆索引与检索（list_memory_documents）。
# 逗号分隔；绝对路径或相对 LUCKBOT_STATE_DIR。仅当路径存在且后缀为 .md 才生效；逻辑名为 extra/<文件名>，
# memory_get 白名单按文件名匹配（paths.py）。
# 场景：项目外的笔记、只读知识库 md、临时摘抄文件，希望被 memory_search 搜到又不想拷进 memory/ 目录。
# 默认：空表示无额外文件。

# -----------------------------------------------------------------------------
# 百炼向量（agent/memory/embeddings.py，须 pip install dashscope）
# -----------------------------------------------------------------------------
DASHSCOPE_API_KEY=
# 作用：阿里云百炼 API Key；嵌入与 rerank（未单独指定 rerank key 时）共用。
# 默认：未设置则 build_embedding_provider / 检索侧无 key 时会报错或跳过需 key 的步骤。
LUCKBOT_MEMORY_EMBEDDING_MODEL=text-embedding-v4
# 作用：百炼嵌入模型名；须非空，未设置则 build_embedding_provider 会 RuntimeError。
LUCKBOT_MEMORY_EMBEDDING_DIM=1024
# 作用：写入前截断为前 N 维并 L2 归一化；须与 sqlite-vec 的 float[N]、模型实际输出维一致。
# 非法整数：索引侧回退 1536；Provider 侧不按该变量截断（见 embeddings与插件解析逻辑）。
LUCKBOT_MEMORY_DASHSCOPE_EMBED_BATCH=10
# 作用：每批 TextEmbedding 文档条数（百炼单批上限约 10，更大可能 API 失败）。
# 默认：10。空或非法整数回退 10；与 1 取 max。

# -----------------------------------------------------------------------------
# 混合检索权重与结果规模（agent/built_in/memory_plugin _search_options、search.py）
# -----------------------------------------------------------------------------
LUCKBOT_MEMORY_VECTOR_WEIGHT=0.7
# 作用：混合检索融合中向量路权重（与 TEXT_WEIGHT 组合，见 search.py）。
# 默认：0.7。非法浮点：回退默认。
LUCKBOT_MEMORY_TEXT_WEIGHT=0.3
# 作用：融合分数中全文（BM25）路权重。
# 默认：0.3。非法浮点：回退默认。
LUCKBOT_MEMORY_MIN_SCORE=0.35
# 作用：融合分低于此阈值的 chunk 不进入候选池。
# 默认：0.35。非法浮点：回退默认。
LUCKBOT_MEMORY_MAX_RESULTS=6
# 作用：memory_search 默认返回条数上限（工具参数 max_results 可覆盖）。
# 默认：6。非法整数：回退默认。工具侧单次调用会 clamp 到 [1, 50]。
LUCKBOT_MEMORY_SEARCH_SNIPPET_MAX_CHARS=0
# 作用：memory_search 每条结果里 snippet 的最大字符数。
# 默认：0 表示不截断，返回索引中的整段 chunk 正文（与分块大小一致，便于 search→按需 memory_get）。
# 设为 >0 时超长则截断并加「…」，用于压低单次工具返回体积。
# LUCKBOT_MEMORY_RERANK_DOC_MAX_CHARS=8000
# 作用：启用 rerank 时，送入重排序 API 的单条文档长度上限（默认 8000）。0 表示不截断。
LUCKBOT_MEMORY_PREFILTER_M=256
# 作用：混合检索里「全文」一路：SQLite FTS5（BM25 关键词打分）先筛出至多 M 条 chunk，再与向量路融合。
# 当未启用 sqlite-vec、走 Python 余弦时，也会在较大候选集上先按 FTS 分数截断到 M 条再算向量，控制耗时。
# 256表示「关键词命中里最多带 256 条进下一轮」，增大更全但更慢，减小更快可能漏召回。
# 默认：256。空或非法整数回退 256。
LUCKBOT_MEMORY_VEC_KNN_K=64
# 作用：启用 sqlite-vec 时，向量 KNN 的近邻个数 k（按距离取最近的 k 个 chunk 再参与融合）。
# FTS 与 KNN 是两路：FTS=关键词匹配；KNN=embedding 最近邻。最终分数由 VECTOR_WEIGHT / TEXT_WEIGHT 加权（search.py）。
# 默认：64。空或非法整数回退 64。

# -----------------------------------------------------------------------------
# 分块、向量扩展、监听、读文件（chunking、sqlite_vec、MemoryPlugin）
# -----------------------------------------------------------------------------
LUCKBOT_MEMORY_CHUNK_TOKENS=400
# 作用：Markdown 分块目标 token 数（近似，再换算为字符窗口）。
# 默认：400。空或非法整数回退 400。
LUCKBOT_MEMORY_CHUNK_OVERLAP=80
# 作用：分块重叠 token 数（再换算为字符 overlap，下限 0）。
# 默认：80。空或非法整数回退 80。
LUCKBOT_MEMORY_USE_SQLITE_VEC=1
# 作用：是否尝试加载 sqlite-vec 做 KNN；失败则日志 warning 并回退 Python 余弦。
# 默认：尝试加载。关闭：0 / false / no / off。
LUCKBOT_MEMORY_WATCH=1
# 作用：是否监听 memory_root 下 .md 变更（需 pip install watchdog）。
# 默认：开启。关闭：0 / false / no / off；未装 watchdog 则自动跳过监听。
LUCKBOT_MEMORY_GET_MAX_LINES=10000
# 作用：memory_get 单次返回行数硬上限（截断）。
# 默认：500（memory_tools.py）；此处示例 10000 便于本地读长文。空或非法整数回退 500。

# -----------------------------------------------------------------------------
# 会话归档到 Markdown（agent/memory/session_memory.py，CLI /new）
# -----------------------------------------------------------------------------
LUCKBOT_SESSION_MEMORY_LAST_N=15
# 作用：/new 归档时，从当前活动会话中提取最近若干条 user/assistant，生成 memory/YYYY-MM-DD-{slug}.md。
# 旧 transcript 会保留为动态记忆，随后切换到新的 session_id。
# 默认：15。空或非法整数回退 15；≤0 表示不过滤条数。

# -----------------------------------------------------------------------------
# 百炼 Rerank 与 MMR（agent/memory/rerank.py、search.py）
# -----------------------------------------------------------------------------
LUCKBOT_MEMORY_RERANK_MODE=off
# 作用：rerank 档位 off / auto / force。auto：候选池条数 ≥ MIN 且具备调用条件时才请求。
# 默认：未设或非法值视为 off。无 API key 时即使 force 也不会实际请求 rerank。
LUCKBOT_MEMORY_RERANK_MIN_CANDIDATES=8
# 作用：RERANK_MODE=auto 时候选池最小条数。
# 默认：8。非法整数：回退默认；负数会与 0 取 max。
LUCKBOT_MEMORY_RERANK_API_KEY=
# 作用：rerank 专用 Bearer；空则回退 DASHSCOPE_API_KEY。
# 默认：空（用 DASHSCOPE_API_KEY）。
LUCKBOT_MEMORY_RERANK_MODEL=qwen3-vl-rerank
# 作用：百炼 text-rerank 模型名（仅读本变量；与 DASHSCOPE_API_KEY 或 LUCKBOT_MEMORY_RERANK_API_KEY 配套）。
# 须非空：实际调用 rerank API 时若仍为空会 RuntimeError（不设默认，与 key 显式配套）。
LUCKBOT_MEMORY_MMR_MODE=off
# 作用：MMR 档位 off / auto / force（逻辑同 rerank）。无查询向量时 MMR 不会生效。
# 默认：未设或非法视为 off。
LUCKBOT_MEMORY_MMR_MIN_CANDIDATES=8
# 作用：MMR 在 auto 模式下候选池最小条数。
# 默认：8。非法整数：回退默认。
LUCKBOT_MEMORY_MMR_LAMBDA=0.5
# 作用：MMR 中 relevance 与多样性的权重 λ（λ·sim(q,c) − (1−λ)·max_sim(c,已选)）。
# 默认：0.5。空或非法浮点回退 0.5。超出 [0,1] 仍参与计算，语义可能怪异。

# （memory_search 工具参数 rerank / mmr 可在单次调用时覆盖上述 MODE，见 SearchOptions。）
# -----------------------------------------------------------------------------
# 技能插件（agent/built_in/skills_plugin）
# -----------------------------------------------------------------------------
LUCKBOT_SKILLS_DIR=
# 作用：在默认技能根之外追加扫描目录（逗号分隔，expanduser）。每棵目录树下递归查找 SKILL.md（skills_plugin/registry.py）。
# 默认扫描顺序：项目 .luckbot/skills → 用户 ~/.luckbot/skills → 本变量列出的目录。
# 场景：把技能仓放在任意路径、多仓库共用一套技能、CI/容器挂载外部技能包。
# 默认：空表示不追加目录。

# -----------------------------------------------------------------------------
# Gateway / Feishu（gateway/app.py、gateway/adapters/feishu*.py）
# -----------------------------------------------------------------------------
LUCKBOT_GATEWAY_HOST=0.0.0.0
# 作用：luckbot-gateway FastAPI 服务监听地址。
LUCKBOT_GATEWAY_PORT=8000
# 作用：luckbot-gateway FastAPI 服务监听端口。
FEISHU_APP_ID=
# 作用：飞书自建应用 app_id；发送消息与 token 获取都依赖它。
FEISHU_APP_SECRET=
# 作用：飞书自建应用 app_secret。
FEISHU_VERIFICATION_TOKEN=
# 作用：飞书事件订阅校验 token；配置后 gateway 会校验请求体里的 token。
FEISHU_API_BASE_URL=https://open.feishu.cn
# 作用：飞书 OpenAPI 根地址；默认中国站。
