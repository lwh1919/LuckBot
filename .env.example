# =============================================================================
# LuckBot 环境变量示例
# 复制为 .env 后填写；不要把真实 .env 提交到仓库。
# =============================================================================

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
# OpenAI 兼容 Chat Completions API。三项均需非空。
LUCKBOT_MODEL_BASE_URL=https://api.openai.com/v1
LUCKBOT_MODEL_API_KEY=
LUCKBOT_MODEL_NAME=gpt-4o-mini

# -----------------------------------------------------------------------------
# 项目路径、运行与日志
# -----------------------------------------------------------------------------
# 项目根目录；通常不需要设置，代码会从 pyproject.toml 自动定位。
LUCKBOT_PROJECT_ROOT=

# 单轮 ReAct 最大步数。
LUCKBOT_RECURSION_LIMIT=25

# Python logging 级别：DEBUG / INFO / WARNING / ERROR。
LUCKBOT_LOG_LEVEL=WARNING

# -----------------------------------------------------------------------------
# Session / Owner
# -----------------------------------------------------------------------------
# 当前 CLI 会话名；本地 CLI 会映射为 local:<name>，gateway CLI 映射为 gateway:cli:<name>。
LUCKBOT_SESSION=default

# 运行态数据根目录；默认 <project>/.luckbot/state。
LUCKBOT_STATE_DIR=

# 长期记忆 owner。单用户部署建议设置为稳定值，如 user:lwh。
LUCKBOT_OWNER_ID=local

# 是否持久化 session transcript。关闭值：0 / false / no / off。
LUCKBOT_SESSION_PERSIST=1

# -----------------------------------------------------------------------------
# Memory 基础能力
# -----------------------------------------------------------------------------
# 是否启用 MemoryPlugin。关闭值：0 / false / no / off。
LUCKBOT_MEMORY_ENABLED=1

# 额外加入长期记忆索引的单个 Markdown 文件，逗号分隔。
LUCKBOT_MEMORY_EXTRA_PATHS=

# memory_get 单次返回最大行数。
LUCKBOT_MEMORY_GET_MAX_LINES=500

# /session new 归档最近多少条 user/assistant 消息到长期记忆 Markdown。
LUCKBOT_SESSION_MEMORY_LAST_N=15

# Markdown 分块配置。
LUCKBOT_MEMORY_CHUNK_TOKENS=400
LUCKBOT_MEMORY_CHUNK_OVERLAP=80

# 是否监听 memory_root 下 Markdown 变更。关闭值：0 / false / no / off。
LUCKBOT_MEMORY_WATCH=1

# -----------------------------------------------------------------------------
# Memory Embedding / Vector
# -----------------------------------------------------------------------------
# 百炼 DashScope API Key。嵌入和 rerank 默认共用它。
DASHSCOPE_API_KEY=

# 嵌入模型名；使用 memory_search 前需要配置。
LUCKBOT_MEMORY_EMBEDDING_MODEL=text-embedding-v4

# 截断向量维度；需与模型输出和索引表一致。
LUCKBOT_MEMORY_EMBEDDING_DIM=1024

# DashScope embedding 批大小。
LUCKBOT_MEMORY_DASHSCOPE_EMBED_BATCH=10

# 是否尝试加载 sqlite-vec 做 KNN。失败会回退 Python 余弦。
LUCKBOT_MEMORY_USE_SQLITE_VEC=1

# -----------------------------------------------------------------------------
# Memory Search
# -----------------------------------------------------------------------------
LUCKBOT_MEMORY_VECTOR_WEIGHT=0.7
LUCKBOT_MEMORY_TEXT_WEIGHT=0.3
LUCKBOT_MEMORY_MIN_SCORE=0.35
LUCKBOT_MEMORY_MAX_RESULTS=6
LUCKBOT_MEMORY_PREFILTER_M=256
LUCKBOT_MEMORY_VEC_KNN_K=64

# 0 表示 memory_search 返回完整 chunk；>0 时按字符截断 snippet。
LUCKBOT_MEMORY_SEARCH_SNIPPET_MAX_CHARS=0

# Rerank 文档截断长度；0 表示不截断。
LUCKBOT_MEMORY_RERANK_DOC_MAX_CHARS=8000

# -----------------------------------------------------------------------------
# Memory Compaction / Flush
# -----------------------------------------------------------------------------
# 空值表示不启用上下文压缩。
LUCKBOT_CONTEXT_TOKEN_BUDGET=
LUCKBOT_CONTEXT_KEEP_RECENT=10

# 压缩前是否运行 memory flush agent。关闭值：0 / false / no / off。
LUCKBOT_MEMORY_FLUSH=1
LUCKBOT_MEMORY_FLUSH_MAX_STEPS=12
LUCKBOT_MEMORY_FLUSH_MAX_WRITE_CHARS=524288

# -----------------------------------------------------------------------------
# Memory Rerank / MMR
# -----------------------------------------------------------------------------
# 模式：off / auto / force。
LUCKBOT_MEMORY_RERANK_MODE=off
LUCKBOT_MEMORY_RERANK_MIN_CANDIDATES=8
LUCKBOT_MEMORY_RERANK_API_KEY=
LUCKBOT_MEMORY_RERANK_MODEL=qwen3-vl-rerank

# 模式：off / auto / force。
LUCKBOT_MEMORY_MMR_MODE=off
LUCKBOT_MEMORY_MMR_MIN_CANDIDATES=8
LUCKBOT_MEMORY_MMR_LAMBDA=0.5

# -----------------------------------------------------------------------------
# MCP
# -----------------------------------------------------------------------------
# MCP 配置读取刷新策略：config / always。
LUCKBOT_MCP_REFRESH_POLICY=config

# MCP 配置文件当前固定为项目内 .luckbot/mcp.json。

# -----------------------------------------------------------------------------
# Skills
# -----------------------------------------------------------------------------
# 额外技能目录，逗号分隔；每棵目录递归查找 SKILL.md。
LUCKBOT_SKILLS_DIR=

# -----------------------------------------------------------------------------
# Gateway / CLI Remote
# -----------------------------------------------------------------------------
# gateway server 监听地址。
LUCKBOT_GATEWAY_HOST=0.0.0.0
LUCKBOT_GATEWAY_PORT=8000

# CLI 连接 gateway 的 base URL；设置后优先于 HOST/PORT。
LUCKBOT_GATEWAY_URL=

# luckbot gateway 不带 URL 时是否自动启动本地 gateway。关闭值：0。
LUCKBOT_GATEWAY_AUTOSTART=1

# CLI 等待 gateway 响应的超时时间，单位秒。
LUCKBOT_GATEWAY_CLIENT_TIMEOUT=300

# CLI remote 简单 Bearer key。server 配了 SERVER_KEY 后，client 需配置相同 CLIENT_KEY。
LUCKBOT_GATEWAY_SERVER_KEY=
LUCKBOT_GATEWAY_CLIENT_KEY=

# -----------------------------------------------------------------------------
# Feishu
# -----------------------------------------------------------------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_API_BASE_URL=https://open.feishu.cn

# -----------------------------------------------------------------------------
# Observability / LangSmith
# -----------------------------------------------------------------------------
# OpenTelemetry 总开关。关闭值：0 / false / no / off。
LUCKBOT_OBSERVABILITY_ENABLED=0

# OTLP HTTP endpoint，例如 http://localhost:4318。
LUCKBOT_OTEL_EXPORTER_OTLP_ENDPOINT=
LUCKBOT_OTEL_EXPORTER_OTLP_HEADERS=
LUCKBOT_OTEL_AUTO_INSTRUMENT_FASTAPI=1

LUCKBOT_SERVICE_NAME=luckbot
LUCKBOT_SERVICE_VERSION=0.1.0
LUCKBOT_ENV=dev

# LuckBot 当前主开关；LANGSMITH_TRACING 仅作为兼容默认值读取。
LUCKBOT_LANGSMITH_ENABLED=0
LUCKBOT_LANGSMITH_PROJECT=luckbot
LANGSMITH_PROJECT=
LANGSMITH_TRACING=0
LANGSMITH_API_KEY=
