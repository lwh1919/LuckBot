# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ── 虚拟环境 ─────────────────────────────────────────────────────────────────
.venv/
.venv_ci/
venv/
ENV/

# ── 密钥 / 本地配置 ──────────────────────────────────────────────────────────
.env
.env.local

# ── 打包产物 ─────────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/

# ── 测试 / 覆盖率 ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
tests/__pycache__/
tests/.pytest_cache/
tests/.artifacts/
tests/tmp/
tests/output/

# ── Python 工具缓存 ─────────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/
.pyre/

# ── 日志 ─────────────────────────────────────────────────────────────────────
*.log

# ── 本地数据库 / 密钥材料 ────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.pem
*.key
*.p12
*.crt
*.csr

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.orig

# ── LuckBot 本地运行产物 / 配置（保留目录名）────────────────────────────────
.luckbot/*
!.luckbot/

# ── mydocs 本地任务过程（保留模板与项目真相文档）────────────────────────────
mydocs/specs/*.md
!mydocs/specs/_template.md
mydocs/micro_specs/*.md
!mydocs/micro_specs/_template.md
